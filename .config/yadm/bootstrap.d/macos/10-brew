#!/usr/bin/env bash
set -euo pipefail

# Source libs
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../lib" && pwd)"
source "$SCRIPT_DIR/logging"

REPO_ROOT="${REPO_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../dotfiles" && pwd)}"
CORE="$REPO_ROOT/.config/yadm/packages/core.txt"

# Install Homebrew if missing
if ! command -v brew &>/dev/null; then
  log "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Install core cross-platform packages
log "Installing core packages..."
while IFS= read -r pkg; do
  brew install "$pkg"
done < <(grep -v '^\s*#' "$CORE" | grep -v '^\s*$')

# Install macOS-specific packages and casks from ~/.Brewfile
if [[ -f "$HOME/.Brewfile" ]]; then
  log "Running brew bundle for macOS-specific packages..."
  brew bundle --global
else
  warn "~/.Brewfile not found, skipping brew bundle"
fi
