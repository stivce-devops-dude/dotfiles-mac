#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../lib" && pwd)"
source "$SCRIPT_DIR/logging"

REPO_ROOT="${REPO_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../dotfiles" && pwd)}"
CORE="$REPO_ROOT/.config/yadm/packages/core.txt"

log "Starting brew setup..."

if ! command -v brew &>/dev/null; then
  log "Installing Homebrew..."
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

log "Ensuring brew is in PATH..."
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

BREWFILE="$HOME/.Brewfile"
if [[ -f "$BREWFILE" ]]; then
  log "Running brew bundle (may ask for admin password once)..."
  brew bundle --global 2>&1 || true
else
  warn "~/.Brewfile not found, skipping brew bundle"
fi
